{
  "name": "solar-panel-calculator",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:content && npm run lint:content-style && astro build && npm run check:links",
    "preview": "astro preview",
    "deploy": "wrangler deploy",
    "validate:content": "tsx scripts/validate-content.ts",
    "lint:content-style": "tsx scripts/lint-content-style.ts",
    "check:links": "node scripts/check-links.mjs",
    "test": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.2.1",
    "@tailwindcss/vite": "^4.1.4",
    "astro": "^5.7.4",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
