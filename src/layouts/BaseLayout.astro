---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import SearchConsole from '../components/SearchConsole.astro';
import ServiceWorkerCleanup from '../components/ServiceWorkerCleanup.astro';
import { SITE_NAME } from '../lib/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Optional override; defaults to the canonical URL of the current path. */
  canonical?: string;
  /** Extra JSON-LD structured data blocks to inject into <head>. */
  structuredData?: object[];
  /** Absolute URL of the social/OG share image (e.g. a generated card). */
  ogImage?: string;
}

const { title, description, canonical, structuredData = [], ogImage } = Astro.props;

// TODO: canonical URLs use the placeholder domain from astro.config.mjs —
// swap `site` there for the real domain before launch.
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Remove any previously-installed third-party ad service worker -->
    <ServiceWorkerCleanup />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="impact-site-verification" value="81060dfc-271c-4176-9cb0-0fd0b5a598ed" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    {ogImage ? (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImage} />
      </>
    ) : (
      <meta name="twitter:card" content="summary" />
    )}
    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
    <SearchConsole />
    <GoogleAnalytics />
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="LzaizpfW8j/SrIjJj3xu7g" async></script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
