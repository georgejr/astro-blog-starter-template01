---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import PostGrid from '../../components/PostGrid.astro';
import Pagination from '../../components/Pagination.astro';
import { CALCULATOR_LINKS } from '../../lib/site';
import { getPublishedPosts, BLOG_PAGE_SIZE } from '../../lib/content';
import { CATEGORIES, taxonomySlug } from '../../lib/taxonomy';

// Page 1 of the blog. Pages 2+ live at /blog/page/<n>/ (blog/page/[page].astro),
// which keeps the article route /blog/<slug>/ free of a pagination conflict.
const allPosts = await getPublishedPosts();
const posts = allPosts.slice(0, BLOG_PAGE_SIZE);
const lastPage = Math.max(1, Math.ceil(allPosts.length / BLOG_PAGE_SIZE));

const categories = CATEGORIES.filter((category) =>
  allPosts.some((post) => post.data.category === category),
);
---

<BaseLayout
  title="Solar Blog – Guides on Solar Panels, Costs & Savings"
  description="Practical guides on solar panel sizing, costs, savings, batteries, and tax credits — written to help homeowners make informed solar decisions."
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <header class="mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Solar Blog</h1>
      <p class="mt-4 text-lg text-slate-600">
        Practical, no-hype guides on solar sizing, costs, batteries, and payback.
      </p>
      {categories.length > 1 && (
        <nav class="mt-6 flex flex-wrap justify-center gap-2" aria-label="Categories">
          {categories.map((category) => (
            <a
              href={`/category/${taxonomySlug(category)}/`}
              class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-medium text-slate-600 hover:border-brand-400 hover:text-brand-700"
            >
              {category}
            </a>
          ))}
        </nav>
      )}
    </header>

    <PostGrid posts={posts} />

    <Pagination
      currentPage={1}
      lastPage={lastPage}
      nextUrl={lastPage > 1 ? '/blog/page/2/' : undefined}
    />

    <div class="mx-auto mt-16 max-w-4xl">
      <RelatedLinks links={CALCULATOR_LINKS} heading="Try Our Calculators" />
    </div>
  </div>
</BaseLayout>
