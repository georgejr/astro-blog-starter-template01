---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import AdSlot from '../../components/AdSlot.astro';
import { CALCULATOR_LINKS } from '../../lib/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const dateFormat = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Solar Blog – Guides on Solar Panels, Costs & Savings"
  description="Practical guides on solar panel sizing, costs, savings, batteries, and tax credits — written to help homeowners make informed solar decisions."
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <header class="mx-auto max-w-2xl text-center">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">Solar Blog</h1>
      <p class="mt-4 text-lg text-slate-600">
        Practical, no-hype guides on solar sizing, costs, batteries, and payback.
      </p>
    </header>

    <ul class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-2">
      {posts.map((post) => (
        <li>
          <a
            href={`/blog/${post.id}/`}
            class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-400 hover:shadow-md"
          >
            <time datetime={post.data.date.toISOString()} class="text-xs font-medium text-slate-400 uppercase">
              {dateFormat.format(post.data.date)}
            </time>
            <h2 class="mt-2 font-semibold text-slate-900">{post.data.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{post.data.description}</p>
            <span class="mt-4 text-sm font-medium text-brand-700">Read article &rarr;</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mx-auto mt-16 max-w-4xl">
      <AdSlot name="blog-index" />
      <RelatedLinks links={CALCULATOR_LINKS} heading="Try Our Calculators" />
    </div>
  </div>
</BaseLayout>
