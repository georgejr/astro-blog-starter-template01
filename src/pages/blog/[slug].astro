---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisclaimerBox from '../../components/DisclaimerBox.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import AdSlot from '../../components/AdSlot.astro';
import BidvertiserWidget from '../../components/BidvertiserWidget.astro';
import { CALCULATOR_LINKS, SITE_NAME } from '../../lib/site';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';
import { articlePath, getPrevNext, getPublishedPaths } from '../../lib/content';
import { taxonomySlug } from '../../lib/taxonomy';

// Routes are generated for PUBLISHED articles only: a scheduled or draft
// article has no URL in the built site at all (not just noindex).
export async function getStaticPaths() {
  return getPublishedPaths();
}

const { post } = Astro.props;
const { Content } = await render(post);
const { prev, next } = await getPrevNext(post);

const dateFormat = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalUrl = new URL(articlePath(post), Astro.site).href;
const ogImage = new URL(`/og/${Astro.params.slug}.png`, Astro.site).href;
const categoryUrl = new URL(`/category/${taxonomySlug(post.data.category)}/`, Astro.site).href;

const structuredData = [
  articleSchema({
    headline: post.data.title,
    description: post.data.description,
    url: canonicalUrl,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: post.data.updatedDate?.toISOString(),
    author: post.data.author,
    publisher: SITE_NAME,
  }),
  breadcrumbSchema([
    { name: 'Home', url: new URL('/', Astro.site).href },
    { name: 'Solar Blog', url: new URL('/blog/', Astro.site).href },
    { name: post.data.category, url: categoryUrl },
    { name: post.data.title, url: canonicalUrl },
  ]),
];
---

<BaseLayout
  title={`${post.data.title} – Solar Blog`}
  description={post.data.description}
  structuredData={structuredData}
  ogImage={ogImage}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <header>
      <nav class="text-sm font-medium text-brand-700" aria-label="Breadcrumb">
        <a href="/blog/" class="hover:underline">&larr; All articles</a>
        <span class="mx-2 text-slate-300">·</span>
        <a href={`/category/${taxonomySlug(post.data.category)}/`} class="hover:underline">
          {post.data.category}
        </a>
      </nav>
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        {post.data.title}
      </h1>
      <time datetime={post.data.publishDate.toISOString()} class="mt-3 block text-sm text-slate-500">
        {dateFormat.format(post.data.publishDate)}
        {post.data.updatedDate && (
          <span class="text-slate-400">
            &nbsp;· Updated {dateFormat.format(post.data.updatedDate)}
          </span>
        )}
      </time>
    </header>

    <img
      src={`/og/${Astro.params.slug}.png`}
      width="1200"
      height="630"
      alt={post.data.title}
      class="mt-6 aspect-[1200/630] w-full rounded-2xl border border-slate-200 bg-slate-50"
      loading="eager"
    />

    <AdSlot name="blog-top" />

    <div
      class="blog-content mt-8 space-y-5 leading-relaxed text-slate-700
        [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-slate-900
        [&_h3]:mt-8 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-slate-900
        [&_a]:text-brand-700 [&_a]:underline
        [&_ul]:list-disc [&_ul]:space-y-1 [&_ul]:pl-5
        [&_ol]:list-decimal [&_ol]:space-y-1 [&_ol]:pl-5
        [&_table]:w-full [&_table]:border-collapse [&_table]:text-sm
        [&_th]:border-b [&_th]:border-slate-300 [&_th]:py-2 [&_th]:pr-4 [&_th]:text-left [&_th]:font-semibold [&_th]:text-slate-900
        [&_td]:border-b [&_td]:border-slate-200 [&_td]:py-2 [&_td]:pr-4
        [&_blockquote]:border-l-4 [&_blockquote]:border-brand-300 [&_blockquote]:pl-4 [&_blockquote]:text-slate-600 [&_blockquote]:italic
        [&_strong]:text-slate-900"
    >
      <Content />
    </div>

    <AdSlot name="blog-bottom" format="in-article" />

    <RelatedArticles post={post} />

    {(prev || next) && (
      <nav class="mt-12 grid gap-4 border-t border-slate-200 pt-8 sm:grid-cols-2" aria-label="Article navigation">
        <div>
          {prev && (
            <a href={articlePath(prev)} class="group block">
              <span class="text-xs font-medium tracking-wide text-slate-400 uppercase">Previous article</span>
              <span class="mt-1 block font-medium text-slate-900 group-hover:text-brand-700">
                {prev.data.title}
              </span>
            </a>
          )}
        </div>
        <div class="sm:text-right">
          {next && (
            <a href={articlePath(next)} class="group block">
              <span class="text-xs font-medium tracking-wide text-slate-400 uppercase">Next article</span>
              <span class="mt-1 block font-medium text-slate-900 group-hover:text-brand-700">
                {next.data.title}
              </span>
            </a>
          )}
        </div>
      </nav>
    )}

    <div class="mt-12 space-y-12">
      <DisclaimerBox />
      <RelatedLinks links={CALCULATOR_LINKS} />
    </div>

    <BidvertiserWidget slot="article-bottom" rows={2} cols={5} mobilecols={1} />
  </article>
</BaseLayout>
