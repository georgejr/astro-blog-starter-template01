---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import { CALCULATOR_LINKS } from '../../lib/site';
import { getPublishedPosts } from '../../lib/content';
import { CATEGORIES, taxonomySlug } from '../../lib/taxonomy';

// A category route exists only while it has at least one published article.
export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return CATEGORIES.filter((category) => posts.some((post) => post.data.category === category)).map(
    (category) => ({
      params: { slug: taxonomySlug(category) },
      props: { category, posts: posts.filter((post) => post.data.category === category) },
    }),
  );
}

const { category, posts } = Astro.props;
---

<BaseLayout
  title={`${category} – Solar Blog`}
  description={`All published SunMetricLab articles about ${category.toLowerCase()}: practical guides for US homeowners considering solar.`}
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <header class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-medium text-brand-700">
        <a href="/blog/" class="hover:underline">Solar Blog</a>
      </p>
      <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
        {category}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        {posts.length} {posts.length === 1 ? 'article' : 'articles'} in this category.
      </p>
    </header>

    <ul class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-2">
      {posts.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))}
    </ul>

    <div class="mx-auto mt-16 max-w-4xl">
      <RelatedLinks links={CALCULATOR_LINKS} heading="Try Our Calculators" />
    </div>
  </div>
</BaseLayout>
