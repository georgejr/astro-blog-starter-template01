---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DisclaimerBox from '../../components/DisclaimerBox.astro';
import RelatedLinks from '../../components/RelatedLinks.astro';
import BidvertiserBanner from '../../components/BidvertiserBanner.astro';
import { CALCULATOR_LINKS, SITE_NAME } from '../../lib/site';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';
import {
  STATE_SOLAR,
  ASSUMPTIONS,
  grossCost,
  netCost,
  annualProduction,
  annualSavings,
  paybackYears,
  stateSlug,
} from '../../data/state-solar';

export async function getStaticPaths() {
  return STATE_SOLAR.map((s) => ({ params: { state: stateSlug(s) }, props: { s } }));
}

const { s } = Astro.props;

const usd = (n) => `$${(Math.round(n / 100) * 100).toLocaleString('en-US')}`;
const kwh = (n) => `${(Math.round(n / 10) * 10).toLocaleString('en-US')} kWh`;
const kw = ASSUMPTIONS.representativeKw;
const sizes = [6, 8, 10];
const payback = paybackYears(kw, s);
const creditPct = Math.round(ASSUMPTIONS.federalCreditRate * 100);

const sunDesc =
  s.sunHours >= 5.5 ? 'well above the national average' : s.sunHours >= 4.5 ? 'about average for the US' : 'below the national average';
const rateDesc =
  s.rateCents >= 22 ? 'among the higher rates in the country' : s.rateCents >= 15 ? 'in the mid-range nationally' : 'on the lower end nationally';
const closer =
  payback <= 9
    ? `Strong sun, high electricity prices, or both put ${s.name} among the faster paybacks in this comparison, and solar tends to make financial sense here for homeowners with suitable roofs.`
    : payback <= 13
      ? `That is a middle-of-the-pack payback, so whether solar is worth it in ${s.name} often comes down to your specific rate, roof, and any state or utility incentives.`
      : `Longer paybacks like this are common where power is cheap or sun is limited. In ${s.name} the federal credit and any local incentives carry more of the case, and shifting usage into daylight hours matters more.`;

const canonicalUrl = new URL(`/solar-panel-cost-by-state/${stateSlug(s)}/`, Astro.site).href;
const structuredData = [
  articleSchema({
    headline: `Solar Panel Cost in ${s.name} (2026 Estimate)`,
    description: `Modeled solar panel cost, savings, and payback for ${s.name}.`,
    url: canonicalUrl,
    datePublished: '2026-07-13T00:00:00Z',
    author: SITE_NAME,
    publisher: SITE_NAME,
  }),
  breadcrumbSchema([
    { name: 'Home', url: new URL('/', Astro.site).href },
    { name: 'Solar Panel Cost by State', url: new URL('/solar-panel-cost-by-state/', Astro.site).href },
    { name: s.name, url: canonicalUrl },
  ]),
];
---

<BaseLayout
  title={`Solar Panel Cost in ${s.name}: 2026 Estimate, Savings and Payback`}
  description={`A modeled estimate of solar panel costs in ${s.name}: 6/8/10 kW system prices after the federal credit, yearly savings, and payback based on the state's sun hours and electricity rate.`}
  structuredData={structuredData}
>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <nav class="text-sm font-medium text-brand-700" aria-label="Breadcrumb">
      <a href="/solar-panel-cost-by-state/" class="hover:underline">&larr; All states</a>
    </nav>
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
      Solar Panel Cost in {s.name} (2026 Estimate)
    </h1>

    <p class="mt-6 leading-relaxed text-slate-700">
      {s.name} averages about <strong>{s.sunHours.toFixed(1)} peak sun hours a day</strong> ({sunDesc})
      with an approximate residential electricity rate near <strong>{s.rateCents}¢/kWh</strong>, {rateDesc}.
      In the model used here, an {kw} kW system in {s.name} produces roughly
      <strong>{kwh(annualProduction(kw, s.sunHours))}</strong> a year and trims about
      <strong>{usd(annualSavings(kw, s))}</strong> off annual electricity costs, paying back its net
      cost in about <strong>{payback.toFixed(1)} years</strong>. {closer}
    </p>

    <BidvertiserBanner />

    <h2 class="mt-10 text-2xl font-bold text-slate-900">Estimated system cost and payback in {s.name}</h2>
    <p class="mt-2 text-slate-600">
      Costs assume roughly ${ASSUMPTIONS.grossPricePerWatt[s.tier].toFixed(2)}/watt installed for {s.name};
      net cost is after the {creditPct}% federal Residential Clean Energy Credit. Savings and payback use
      the state's sun hours and rate above.
    </p>

    <div class="mt-4 overflow-x-auto rounded-xl border border-slate-200">
      <table class="w-full min-w-[520px] border-collapse text-sm">
        <thead>
          <tr class="bg-slate-50 text-left text-slate-600">
            <th class="px-4 py-3 font-semibold">System size</th>
            <th class="px-4 py-3 font-semibold">Gross cost</th>
            <th class="px-4 py-3 font-semibold">Net after credit</th>
            <th class="px-4 py-3 font-semibold">Yearly production</th>
            <th class="px-4 py-3 font-semibold">Yearly savings</th>
            <th class="px-4 py-3 font-semibold">Payback</th>
          </tr>
        </thead>
        <tbody>
          {sizes.map((size) => (
            <tr class="border-t border-slate-200">
              <td class="px-4 py-3 font-medium">{size} kW</td>
              <td class="px-4 py-3">{usd(grossCost(size, s.tier))}</td>
              <td class="px-4 py-3">{usd(netCost(size, s.tier))}</td>
              <td class="px-4 py-3">{kwh(annualProduction(size, s.sunHours))}</td>
              <td class="px-4 py-3">{usd(annualSavings(size, s))}</td>
              <td class="px-4 py-3">{paybackYears(size, s).toFixed(1)} yrs</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2 class="mt-10 text-2xl font-bold text-slate-900">What moves the numbers in {s.name}</h2>
    <p class="mt-2 leading-relaxed text-slate-700">
      Two inputs drive most of the difference between states: how much sun a system sees and what each
      offset kilowatt-hour is worth. {s.name}'s {s.sunHours.toFixed(1)} sun hours set production, and its
      roughly {s.rateCents}¢/kWh rate sets what that production saves. The bigger unknowns are your roof,
      shading, and how your utility compensates exported power, since a lower export rate can pull real
      savings below the retail-rate figure above. The calculators let you replace these state averages
      with your own bill and roof.
    </p>

    <div class="mt-10 space-y-10">
      <DisclaimerBox />
      <RelatedLinks links={CALCULATOR_LINKS} heading="Estimate your own system" />
    </div>
  </article>
</BaseLayout>
