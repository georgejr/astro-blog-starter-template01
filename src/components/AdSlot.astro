---
/**
 * Former AdSense slot. Now renders a 1x4 Bidvertiser native strip at each of
 * the old AdSense positions (homepage, blog list, category, article top and
 * after-content). `name` must be unique per page. The larger 2x5 article
 * grid and the classic calculator-page banner are separate components
 * (BidvertiserWidget / BidvertiserBanner).
 */
import BidvertiserWidget from './BidvertiserWidget.astro';

interface Props {
  name: string;
  /** Kept for call-site compatibility; not used by the native strip. */
  format?: string;
}

const { name } = Astro.props;
---

<BidvertiserWidget slot={name} rows={1} cols={4} mobilecols={2} />
