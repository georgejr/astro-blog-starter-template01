---
/**
 * AdSense slot placeholder.
 *
 * TODO: when the AdSense account is approved, replace the placeholder <div>
 * below with the real ad unit, e.g.:
 *
 *   <ins class="adsbygoogle"
 *        style="display:block"
 *        data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
 *        data-ad-slot="YYYYYYYYYY"
 *        data-ad-format="auto"
 *        data-full-width-responsive="true"></ins>
 *   <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
 *
 * The adsbygoogle.js loader is GoogleAdsense.astro (activated by setting
 * ADSENSE_CLIENT_ID in src/lib/site.ts); it also delivers Google's own
 * consent message, so no separate cookie banner is needed.
 */
interface Props {
  /** Identifier for the placement, e.g. "home-mid", "blog-top". */
  name: string;
  /** Rough shape of the unit — controls the placeholder height. */
  format?: 'horizontal' | 'rectangle';
}

const { name, format = 'horizontal' } = Astro.props;
const heightClass = format === 'rectangle' ? 'min-h-[250px]' : 'min-h-[90px]';
---

<div
  class={`ad-slot mx-auto my-8 flex w-full max-w-3xl items-center justify-center rounded-lg border border-dashed border-slate-300 bg-slate-50 ${heightClass}`}
  data-ad-placement={name}
  aria-hidden="true"
>
  <span class="text-xs tracking-wide text-slate-400 uppercase">Advertisement</span>
</div>
