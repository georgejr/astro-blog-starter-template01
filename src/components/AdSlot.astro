/**
 * Legacy ad-slot placeholder. Monetization moved to Monetag, which places its
 * own formats from a site-wide script (see Monetag.astro) rather than fixed
 * in-content slots, so this component intentionally renders nothing. The
 * `<AdSlot />` call sites are kept so layout/markup history stays intact and
 * a future slot-based network could be wired back in here.
 */
interface Props {
  name?: string;
  format?: string;
}
