---
// Two-column article grid shared by the blog index and its pagination pages.
import PostCard from './PostCard.astro';
import type { BlogEntry } from '../lib/content';

interface Props {
  posts: BlogEntry[];
}

const { posts } = Astro.props;
---

<ul class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-2">
  {posts.map((post) => (
    <>
      <li>
        <PostCard post={post} />
      </li>
    </>
  ))}
</ul>
