---
// Monetag vignette (full-screen interstitial) — article pages only. The
// snippet injects a zone-scoped loader script; kept verbatim from Monetag with
// the zone pulled from site.ts.
import { MONETAG_VIGNETTE_ZONE } from '../lib/site';
---

<script is:inline define:vars={{ zone: MONETAG_VIGNETTE_ZONE }}>
  (function (s) {
    s.dataset.zone = zone;
    s.src = 'https://n6wxm.com/vignette.min.js';
  })(
    [document.documentElement, document.body]
      .filter(Boolean)
      .pop()
      .appendChild(document.createElement('script')),
  );
</script>
