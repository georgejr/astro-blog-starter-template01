---
/**
 * Bidvertiser native widget (ad unit 2106253). Each instance needs a DOM id
 * that is unique on its page, so pass a distinct `slot` per placement. The
 * grid shape is configurable: 1x4 for the horizontal strips (homepage,
 * category, blog list, article top/bottom) and 2x5 for the larger
 * article-bottom recommendation grid.
 */
interface Props {
  slot: string;
  rows?: number;
  cols?: number;
  mobilecols?: number;
}

const { slot, rows = 1, cols = 4, mobilecols = 2 } = Astro.props;
const containerId = `ntv_${slot.replace(/[^a-zA-Z0-9]/g, '_')}`;
---

<div class="mx-auto my-8 w-full max-w-3xl" data-ad-placement={slot}>
  <div id={containerId}></div>
  <script is:inline define:vars={{ containerId, rows, cols, mobilecols }}>
    (function (d) {
      var params = {
        bvwidgetid: containerId,
        bvlinksownid: 2106253,
        rows: rows,
        cols: cols,
        textpos: 'below',
        imagewidth: 150,
        mobilecols: mobilecols,
        cb: new Date().getTime(),
      };
      params.bvwidgetid = containerId + params.cb;
      d.getElementById(containerId).id = params.bvwidgetid;
      var qs = Object.keys(params)
        .reduce(function (a, k) {
          a.push(k + '=' + encodeURIComponent(params[k]));
          return a;
        }, [])
        .join(String.fromCharCode(38));
      var s = d.createElement('script');
      s.type = 'text/javascript';
      s.async = true;
      var p = 'https:' == document.location.protocol ? 'https' : 'http';
      s.src = p + '://cdn.hyperpromote.com/bidvertiser/tags/active/bdvws.js?' + qs;
      d.getElementById(params.bvwidgetid).appendChild(s);
    })(document);
  </script>
</div>
