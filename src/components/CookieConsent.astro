---
// Cookie consent banner. Blocks ad/analytics scripts until the visitor accepts.
// Choice is stored in localStorage under "cookie-consent" ("granted" | "denied").
---

<div
  id="cookie-consent"
  class="fixed inset-x-0 bottom-0 z-50 hidden border-t border-slate-200 bg-white p-4 shadow-[0_-4px_20px_rgba(0,0,0,0.08)]"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie consent"
>
  <div class="mx-auto flex max-w-6xl flex-col items-start gap-4 sm:flex-row sm:items-center">
    <p class="flex-1 text-sm leading-relaxed text-slate-600">
      We use cookies to analyze traffic and to show ads. Advertising and analytics cookies are
      only set if you accept. See our
      <a href="/privacy-policy/" class="text-brand-700 underline">privacy policy</a> for details.
    </p>
    <div class="flex shrink-0 gap-3">
      <button
        id="cookie-decline"
        class="rounded-lg border border-slate-300 px-5 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-100"
      >
        Decline
      </button>
      <button
        id="cookie-accept"
        class="rounded-lg bg-brand-600 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-700"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'cookie-consent';
  const banner = document.getElementById('cookie-consent');

  function loadConsentedScripts() {
    // TODO: load consent-gated scripts here once real IDs exist:
    //
    // 1. AdSense loader:
    //    const s = document.createElement('script');
    //    s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX';
    //    s.async = true;
    //    s.crossOrigin = 'anonymous';
    //    document.head.appendChild(s);
    //
    // 2. Google Analytics 4 (gtag.js) — with Consent Mode v2:
    //    gtag('consent', 'update', {
    //      ad_storage: 'granted', ad_user_data: 'granted',
    //      ad_personalization: 'granted', analytics_storage: 'granted',
    //    });
    //
    // 3. Microsoft Clarity snippet.
    //
    // For EEA traffic Google requires a certified CMP for personalized ads —
    // consider Google's own consent message (via AdSense settings) or a CMP
    // like Cookiebot/Consentmanager, and keep this banner for non-EEA.
  }

  function setConsent(value: 'granted' | 'denied') {
    localStorage.setItem(STORAGE_KEY, value);
    banner?.classList.add('hidden');
    if (value === 'granted') loadConsentedScripts();
  }

  const stored = localStorage.getItem(STORAGE_KEY);
  if (stored === 'granted') {
    loadConsentedScripts();
  } else if (stored !== 'denied') {
    banner?.classList.remove('hidden');
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => setConsent('granted'));
  document.getElementById('cookie-decline')?.addEventListener('click', () => setConsent('denied'));

  // Footer "Cookie settings" link re-opens the banner so consent can be changed.
  document.querySelectorAll('[data-cookie-settings]').forEach((el) => {
    el.addEventListener('click', (event) => {
      event.preventDefault();
      localStorage.removeItem(STORAGE_KEY);
      banner?.classList.remove('hidden');
    });
  });
</script>
