---
// Site-wide Monetag zone tag (replaces AdSense). Rendered in <head> on every
// page via BaseLayout and, for BlogPost pages, via BaseHead.
// data-cfasync="false" stops Cloudflare Rocket Loader from deferring it.
// (The quge5 "Multitag" was removed at the site owner's request; the vignette
// interstitial lives in MonetagVignette.astro.)
import { MONETAG_TAG_SRC } from '../lib/site';
---

<script is:inline src={MONETAG_TAG_SRC} async data-cfasync="false"></script>
