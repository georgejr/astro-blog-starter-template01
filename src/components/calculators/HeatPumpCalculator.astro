---
import InputField from '../InputField.astro';
---

<section class="grid gap-8 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)]">
  <form id="hp-form" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8" novalidate>
    <h2 class="text-lg font-bold text-slate-900">Heating details</h2>
    <p class="mt-1 text-sm text-slate-500">Compares a heat pump against a gas furnace. Results update as you type.</p>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      <InputField id="therms" label="Gas used for heating per year" unit="therms" value={500} min={50} max={2000} step={10} hint="Check winter gas bills; 1 therm ≈ 29.3 kWh of heat." />
      <InputField id="gasPrice" label="Natural gas price" unit="USD/therm" value={1.3} min={0.5} max={4} step={0.05} />
      <InputField id="afue" label="Current furnace efficiency" unit="AFUE %" value={90} min={60} max={99} step={1} />
      <InputField id="cop" label="Heat pump COP (seasonal)" unit="" value={2.8} min={1.5} max={4.5} step={0.1} hint="Cold-climate units: ~2–3 over a season." />
      <InputField id="rate" label="Electricity rate" unit="USD/kWh" value={0.17} min={0.05} max={0.6} step={0.01} />
    </div>
  </form>

  <div id="hp-results" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
    <div class="flex flex-wrap items-baseline justify-between gap-2">
      <p class="text-sm font-semibold tracking-wide text-slate-500 uppercase">Heat pump running cost</p>
      <p class="text-3xl font-extrabold text-slate-900" data-result="hpCost">—</p>
    </div>
    <dl class="mt-6 space-y-3 text-sm">
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Heat delivered per year</dt><dd class="font-semibold text-slate-900" data-result="heat">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Electricity used</dt><dd class="font-semibold text-slate-900" data-result="kwh">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Current gas cost</dt><dd class="font-semibold text-slate-900" data-result="gasCost">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Yearly difference</dt><dd class="font-semibold" data-result="savings">—</dd></div>
    </dl>
    <p class="mt-6 rounded-lg bg-white p-4 text-sm leading-relaxed text-slate-600" data-result="verdict"></p>
  </div>
</section>

<script>
  const form = document.getElementById('hp-form') as HTMLFormElement | null;
  const panel = document.getElementById('hp-results');
  if (form && panel) {
    const num = (id: string) => Number.parseFloat((form.elements.namedItem(id) as HTMLInputElement).value) || 0;
    const usd = (n: number) => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const set = (name: string, value: string) => { const el = panel.querySelector<HTMLElement>(`[data-result="${name}"]`); if (el) el.textContent = value; };

    const update = () => {
      const therms = num('therms');
      const gasPrice = num('gasPrice');
      const afue = num('afue') / 100;
      const cop = num('cop') || 1;
      const rate = num('rate');
      const usefulHeatKwh = therms * 29.3 * afue; // heat actually delivered
      const hpKwh = usefulHeatKwh / cop;
      const hpCost = hpKwh * rate;
      const gasCost = therms * gasPrice;
      const savings = gasCost - hpCost;

      set('hpCost', `${usd(hpCost)}/yr`);
      set('heat', `${Math.round(usefulHeatKwh).toLocaleString('en-US')} kWh`);
      set('kwh', `${Math.round(hpKwh).toLocaleString('en-US')} kWh`);
      set('gasCost', `${usd(gasCost)}/yr`);

      const sEl = panel.querySelector<HTMLElement>('[data-result="savings"]');
      if (sEl) { sEl.textContent = savings >= 0 ? `Save ${usd(savings)}/yr` : `Costs ${usd(-savings)} more/yr`; sEl.className = `font-semibold ${savings >= 0 ? 'text-brand-700' : 'text-amber-700'}`; }

      set('verdict', savings >= 0
        ? `Delivering the same heat with a heat pump at a seasonal COP of ${num('cop').toFixed(1)} costs about ${usd(hpCost)} a year in electricity, versus ${usd(gasCost)} on gas — a saving near ${usd(savings)}. Savings grow where electricity is cheap, gas is expensive, or the heat pump holds a higher COP.`
        : `At ${usd(rate)}/kWh and ${usd(gasPrice)}/therm, the heat pump runs about ${usd(-savings)} a year more than gas here. That reverses with cheaper power, pricier gas, or a higher seasonal COP; a heat pump also replaces summer air conditioning, which this heating-only comparison ignores.`);
    };
    form.addEventListener('input', update);
    form.addEventListener('submit', (e) => e.preventDefault());
    update();
  }
</script>
