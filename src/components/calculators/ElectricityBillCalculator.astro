---
import InputField from '../InputField.astro';
---

<section class="grid gap-8 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)]">
  <form id="bill-form" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8" novalidate>
    <h2 class="text-lg font-bold text-slate-900">Your usage</h2>
    <p class="mt-1 text-sm text-slate-500">Results update as you type.</p>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      <InputField id="usage" label="Monthly electricity use" unit="kWh/month" value={900} min={50} max={5000} step={10} hint="US average is roughly 850–900 kWh/month." />
      <InputField id="rate" label="Electricity rate" unit="USD/kWh" value={0.17} min={0.05} max={0.6} step={0.01} />
      <InputField id="fixed" label="Fixed monthly charge" unit="USD" value={12} min={0} max={60} step={1} hint="Utility connection/service fee." />
    </div>
  </form>

  <div id="bill-results" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
    <div class="flex flex-wrap items-baseline justify-between gap-2">
      <p class="text-sm font-semibold tracking-wide text-slate-500 uppercase">Estimated monthly bill</p>
      <p class="text-3xl font-extrabold text-slate-900" data-result="monthly">—</p>
    </div>
    <dl class="mt-6 space-y-3 text-sm">
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Energy charge</dt><dd class="font-semibold text-slate-900" data-result="energy">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Fixed charge</dt><dd class="font-semibold text-slate-900" data-result="fixedOut">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">All-in cost per kWh</dt><dd class="font-semibold text-slate-900" data-result="avg">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Yearly total</dt><dd class="font-semibold text-slate-900" data-result="annual">—</dd></div>
    </dl>
    <p class="mt-6 rounded-lg bg-white p-4 text-sm leading-relaxed text-slate-600" data-result="verdict"></p>
  </div>
</section>

<script>
  const form = document.getElementById('bill-form') as HTMLFormElement | null;
  const panel = document.getElementById('bill-results');
  if (form && panel) {
    const num = (id: string) => Number.parseFloat((form.elements.namedItem(id) as HTMLInputElement).value) || 0;
    const usd = (n: number) => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const set = (name: string, value: string) => { const el = panel.querySelector<HTMLElement>(`[data-result="${name}"]`); if (el) el.textContent = value; };

    const update = () => {
      const usage = num('usage');
      const rate = num('rate');
      const fixed = num('fixed');
      const energy = usage * rate;
      const monthly = energy + fixed;
      const annual = monthly * 12;
      const avg = usage > 0 ? monthly / usage : 0;

      set('monthly', usd(monthly));
      set('energy', usd(energy));
      set('fixedOut', usd(fixed));
      set('avg', `${(avg * 100).toFixed(1)}¢/kWh`);
      set('annual', usd(annual));

      set('verdict', `At ${usage.toLocaleString('en-US')} kWh a month and ${usd(rate)}/kWh, the energy charge is ${usd(energy)}; adding the ${usd(fixed)} fixed fee brings the bill to about ${usd(monthly)} a month, or ${usd(annual)} a year. The fixed fee raises your effective rate to ${(avg * 100).toFixed(1)}¢/kWh — worth remembering, since solar offsets the energy charge but not that fixed fee.`);
    };
    form.addEventListener('input', update);
    form.addEventListener('submit', (e) => e.preventDefault());
    update();
  }
</script>
