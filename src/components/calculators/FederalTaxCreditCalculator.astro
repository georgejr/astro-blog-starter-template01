---
import InputField from '../InputField.astro';
---

<section class="grid gap-8 lg:grid-cols-[minmax(0,5fr)_minmax(0,6fr)]">
  <form id="itc-form" class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8" novalidate>
    <h2 class="text-lg font-bold text-slate-900">Your project</h2>
    <p class="mt-1 text-sm text-slate-500">Results update as you type.</p>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      <InputField id="cost" label="Total qualifying cost" unit="USD" value={22000} min={2000} max={120000} step={100} hint="Equipment plus installation (a paired battery can qualify too)." />
      <InputField id="liability" label="Your federal tax liability" unit="USD/year" value={4000} min={0} max={60000} step={100} hint="Roughly the tax you owe before withholding — see your return." />
    </div>
  </form>

  <div id="itc-results" class="rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
    <div class="flex flex-wrap items-baseline justify-between gap-2">
      <p class="text-sm font-semibold tracking-wide text-slate-500 uppercase">30% credit</p>
      <p class="text-3xl font-extrabold text-brand-700" data-result="credit">—</p>
    </div>
    <dl class="mt-6 space-y-3 text-sm">
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Usable this tax year</dt><dd class="font-semibold text-slate-900" data-result="usable">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Carried to future years</dt><dd class="font-semibold text-slate-900" data-result="carry">—</dd></div>
      <div class="flex justify-between border-t border-slate-200 pt-3"><dt class="text-slate-600">Net cost after credit</dt><dd class="font-semibold text-slate-900" data-result="net">—</dd></div>
    </dl>
    <p class="mt-6 rounded-lg bg-white p-4 text-sm leading-relaxed text-slate-600" data-result="verdict"></p>
  </div>
</section>

<script>
  const form = document.getElementById('itc-form') as HTMLFormElement | null;
  const panel = document.getElementById('itc-results');
  if (form && panel) {
    const num = (id: string) => Number.parseFloat((form.elements.namedItem(id) as HTMLInputElement).value) || 0;
    const usd = (n: number) => n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const set = (name: string, value: string) => { const el = panel.querySelector<HTMLElement>(`[data-result="${name}"]`); if (el) el.textContent = value; };

    const update = () => {
      const cost = num('cost');
      const liability = num('liability');
      const credit = cost * 0.3;
      const usable = Math.min(credit, liability);
      const carry = credit - usable;
      const net = cost - credit;

      set('credit', usd(credit));
      set('usable', usd(usable));
      set('carry', carry > 0 ? usd(carry) : '—');
      set('net', usd(net));

      set('verdict', carry > 0
        ? `A ${usd(cost)} project earns a ${usd(credit)} federal credit (30%). Because it is nonrefundable, only ${usd(usable)} offsets this year's ${usd(liability)} of tax; the remaining ${usd(carry)} generally carries forward to future years until it is used up. Confirm your own liability and eligibility with the IRS or a tax professional.`
        : `A ${usd(cost)} project earns a ${usd(credit)} federal credit (30%), and with ${usd(liability)} of tax liability you can use the full amount this year, bringing the net cost to about ${usd(net)}. The credit is nonrefundable, so it reduces tax owed rather than paying cash back — confirm your situation with the IRS or a tax professional.`);
    };
    form.addEventListener('input', update);
    form.addEventListener('submit', (e) => e.preventDefault());
    update();
  }
</script>
