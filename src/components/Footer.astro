---
import { CALCULATOR_LINKS, DISCLAIMER_TEXT, SITE_NAME } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <p class="font-semibold text-slate-900">{SITE_NAME}</p>
        <p class="mt-2 text-sm text-slate-600">
          Free solar sizing, cost, savings, and payback estimates for US homeowners.
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold tracking-wide text-slate-900 uppercase">Calculators</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          {CALCULATOR_LINKS.map((link) => (
            <li>
              <a href={link.href} class="hover:text-brand-700 hover:underline">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold tracking-wide text-slate-900 uppercase">Site</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li><a href="/blog/" class="hover:text-brand-700 hover:underline">Blog</a></li>
          <li><a href="/solar-panel-cost-by-state/" class="hover:text-brand-700 hover:underline">Solar Cost by State</a></li>
          <li><a href="/solar-panel-cost-by-city/" class="hover:text-brand-700 hover:underline">Solar Cost by City</a></li>
          <li><a href="/contact/" class="hover:text-brand-700 hover:underline">Contact</a></li>
          <li><a href="/privacy-policy/" class="hover:text-brand-700 hover:underline">Privacy Policy</a></li>
          <li><a href="/terms/" class="hover:text-brand-700 hover:underline">Terms of Use</a></li>
          <li><a href="#" data-cookie-settings class="hover:text-brand-700 hover:underline">Cookie Settings</a></li>
        </ul>
      </div>
    </div>
    <p class="mt-10 border-t border-slate-200 pt-6 text-xs leading-relaxed text-slate-500">
      {DISCLAIMER_TEXT}
    </p>
    <p class="mt-4 text-xs text-slate-400">&copy; {year} {SITE_NAME}. All rights reserved.</p>
  </div>
</footer>

<script>
  // Re-opens Google's consent message (AdSense Privacy & messaging) so
  // visitors can revise their choice. No-op until the AdSense script loads.
  document.querySelectorAll('[data-cookie-settings]').forEach((el) => {
    el.addEventListener('click', (event) => {
      event.preventDefault();
      const w = window as typeof window & {
        googlefc?: { callbackQueue?: unknown[]; showRevocationMessage?: () => void };
      };
      w.googlefc = w.googlefc || {};
      w.googlefc.callbackQueue = w.googlefc.callbackQueue || [];
      w.googlefc.callbackQueue.push(() => w.googlefc?.showRevocationMessage?.());
    });
  });
</script>
